# sdist content control. Mirror the wheel exclusions in pyproject.toml's
# [tool.setuptools.exclude-package-data] — without this the sdist auto-includes
# every git-tracked file and the heavy per-cohort expression data (added in a
# later milestone) would balloon the .tar.gz past PyPI's 100 MiB limit.
recursive-exclude cancerdata/data/cancer-reference-expression *
recursive-exclude cancerdata/data/cancer-reference-expression-percentiles *
recursive-exclude cancerdata/data/cancer-reference-expression-representatives *
recursive-exclude cancerdata/data/cancer-reference-expression-within-sample-top5 *
exclude cancerdata/data/pan-cancer-expression.csv
exclude cancerdata/data/hpa-cell-type-expression.csv
